# ─────────────────────────────────────────────────────────────────────────────
# Unity Catalog Browser — environment variable reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local development. Never commit a real .env file.
#
# The variables marked [RUNTIME] are injected automatically by the Databricks
# Apps runtime — you do NOT set these yourself in production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Optional overrides ────────────────────────────────────────────────────────

# Pin a specific SQL Warehouse instead of letting the app auto-discover one.
# If unset, the app picks the first available warehouse in the workspace.
# DATABRICKS_WAREHOUSE_ID=aabbccddeeff0011

# ── Injected by Databricks Apps runtime (do not set manually) ─────────────────

# [RUNTIME] Your workspace URL, e.g. https://dbc-xxxx.cloud.databricks.com
# DATABRICKS_HOST=

# [RUNTIME] The app's service principal credentials (only present when OBO is OFF)
# DATABRICKS_CLIENT_ID=
# DATABRICKS_CLIENT_SECRET=

# [RUNTIME] Numeric workspace ID — used for multi-workspace catalog routing
# DATABRICKS_WORKSPACE_ID=

# [RUNTIME] Port and host uvicorn should bind to (set to 0.0.0.0 / auto port)
# UVICORN_PORT=
# UVICORN_HOST=

# ── Local development only ────────────────────────────────────────────────────

# For local dev, point to your workspace. The Databricks CLI profile is used
# for auth automatically (databricks auth login --profile dev).
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
